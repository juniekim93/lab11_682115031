<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #ffe0f0 0%, #ffc2e0 50%, #ffaed6 100%);
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
    }
    .card {
      background: #fff;
      border-radius: 24px;
      padding: 48px 56px;
      box-shadow: 0 8px 40px rgba(255, 100, 160, 0.18);
      max-width: 420px; width: 100%;
    }
    .emoji { font-size: 40px; text-align: center; margin-bottom: 8px; }
    h1 { font-size: 28px; font-weight: 700; color: #e91e8c; text-align: center; margin-bottom: 6px; }
    .sub { font-size: 13px; color: #bbb; text-align: center; margin-bottom: 28px; }
    .error {
      background: #fff0f6; color: #e91e8c;
      border: 1px solid #ffb3d9; border-radius: 10px;
      padding: 10px 14px; font-size: 13px; margin-bottom: 20px;
    }
    .field { margin-bottom: 18px; }
    label { display: block; font-size: 12px; font-weight: 600; color: #e91e8c; margin-bottom: 6px; }
    input {
      width: 100%; padding: 12px 14px;
      border: 2px solid #ffc2e0; border-radius: 10px;
      font-size: 14px; outline: none; transition: border-color 0.2s; color: #333;
    }
    input:focus { border-color: #e91e8c; }
    input::placeholder { color: #ddd; }
    .btn {
      width: 100%; padding: 14px;
      background: linear-gradient(135deg, #ff6eb4, #e91e8c);
      color: #fff; border: none; border-radius: 12px;
      font-size: 15px; font-weight: 600; cursor: pointer;
      transition: transform 0.15s, box-shadow 0.15s;
      margin-bottom: 12px;
    }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(233,30,140,0.25); }
    .divider {
      text-align: center; font-size: 12px; color: #ccc;
      margin: 16px 0; position: relative;
    }
    .divider::before, .divider::after {
      content: ''; position: absolute; top: 50%;
      width: 42%; height: 1px; background: #f0d0e0;
    }
    .divider::before { left: 0; }
    .divider::after { right: 0; }
    .register-form input { margin-bottom: 10px; }
    .btn-outline {
      width: 100%; padding: 13px;
      background: #fff; color: #e91e8c;
      border: 2px solid #e91e8c; border-radius: 12px;
      font-size: 14px; font-weight: 600; cursor: pointer;
      transition: all 0.15s;
    }
    .btn-outline:hover { background: #fff0f8; }
    .back { display: block; text-align: center; margin-top: 20px; font-size: 13px; color: #bbb; text-decoration: none; }
    .back:hover { color: #e91e8c; }
  </style>
</head>
<body>
  <div class="card">
    <div class="emoji">💗</div>
    <h1>Welcome Back</h1>
    <p class="sub">Login to continue</p>

    <% if (err) { %>
      <div class="error">Invalid email or password. Please try again.</div>
    <% } %>

    <form method="POST" action="/login">
      <div class="field">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" required />
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="••••••••" required />
      </div>
      <button type="submit" class="btn">Login 🌸</button>
    </form>

    <div class="divider">or register for testing</div>

    <form method="POST" action="/register" class="register-form">
      <input type="email" name="email" placeholder="email" required />
      <input type="password" name="password" placeholder="password" required />
      <button type="submit" class="btn-outline">Register</button>
    </form>

    <a href="/" class="back">← Back to Home</a>
  </div>
</body>
</html>
